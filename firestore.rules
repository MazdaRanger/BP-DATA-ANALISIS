rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic validation helper
    function isValidBodyRepairRecord(data) {
      return data.keys().hasAll(['id', 'tanggal', 'week', 'no_spk', 'asuransi', 'jasa_nett', 'part_material_nett', 'expenses_bahan', 'hpp_part_material', 'spkl', 'jumlah_panel', 'wilayah'])
          && data.id is string
          && data.tanggal is string
          && data.no_spk is string
          && data.asuransi is string
          && data.wilayah is string
          && data.week is number
          && data.jasa_nett is number
          && data.part_material_nett is number
          && data.expenses_bahan is number
          && data.hpp_part_material is number
          && data.spkl is number
          && data.jumlah_panel is number;
    }

    // Role helper
    function isSuperAdmin() {
      return request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' || request.auth.uid == 'KP0e80jaapPjDC02InH6Yv7hGwC2');
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    match /system_config/{documentId} {
      allow read, write: if true;
    }

    match /body_repair_records/{documentId} {
      // Require auth for reads, but allow writes if super admin OR just general access for testing (we'll limit to auth users)
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && isValidBodyRepairRecord(request.resource.data);
      allow delete: if request.auth != null;
    }

    match /kanban_records/{documentId} {
      allow read, write: if request.auth != null;
    }

    match /crc_records/{documentId} {
      allow read, write: if request.auth != null;
    }
  }
}
